# ============================================================
# AI Analytics Agent — .gitignore
# ============================================================

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual Environments ───────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Environment Variables (SECRETS!) ───────────────────────
.env
!.env.example

# ── Database ────────────────────────────────────────────────
*.db
*.sqlite3
data/analytics.db

# ── Distribution / Packaging ───────────────────────────────
build/
dist/
*.egg-info/
*.egg
*.whl
*.tar.gz

# ── Testing ─────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ── IDE / Editor ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# ── OS Files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Logs ────────────────────────────────────────────────────
*.log
logs/

# ── Credentials ─────────────────────────────────────────────
credentials/
*.pem
*.key
*.crt

# ── Docker ──────────────────────────────────────────────────
docker-compose.override.yml

# ── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
